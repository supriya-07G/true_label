{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User's health profile and personalization settings.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "age": { "type": "number" },
        "weight": { "type": "number" },
        "gender": { "type": "string" },
        "allergies": { "type": "array", "items": { "type": "string" } },
        "medications": { "type": "array", "items": { "type": "string" } },
        "chronicIllnesses": { "type": "array", "items": { "type": "string" } },
        "dietaryRestrictions": { "type": "array", "items": { "type": "string" } },
        "healthGoals": { "type": "array", "items": { "type": "string" } },
        "scanSettings": {
          "type": "object",
          "properties": {
            "priorityIngredients": { "type": "array", "items": { "type": "string" } },
            "cautionThreshold": { "type": "number" }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "CabinetItem": {
      "title": "Cabinet Item",
      "description": "A food or medicine item stored in the user's cabinet.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["medicine", "food"] },
        "name": { "type": "string" },
        "expiryDate": { "type": "string" },
        "safetyScore": { "type": "number" },
        "status": { "type": "string", "enum": ["safe", "caution", "unsafe"] },
        "addedAt": { "type": "string", "format": "date-time" },
        "ingredients": { "type": "array", "items": { "type": "string" } },
        "calories": { "type": "string" }
      }
    },
    "ScanResult": {
      "title": "Scan Result",
      "description": "Historical result of a product scan.",
      "type": "object",
      "properties": {
        "productName": { "type": "string" },
        "type": { "type": "string", "enum": ["medicine", "food"] },
        "safetyScore": { "type": "number" },
        "status": { "type": "string", "enum": ["safe", "caution", "unsafe"] },
        "summary": { "type": "string" },
        "safetyNote": { "type": "string" },
        "ingredients": { "type": "array" },
        "alternatives": { "type": "array" },
        "restrictedCountries": { "type": "array", "items": { "type": "string" } },
        "expiryDate": { "type": "string" },
        "expiryConfidence": { "type": "string", "enum": ["Low", "Medium", "High"] },
        "scanDate": { "type": "string", "format": "date-time" },
        "isInvalid": { "type": "boolean" },
        "invalidReason": { "type": "string" }
      }
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message in the AI chat history.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "model"] },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile document."
    },
    "/users/{userId}/cabinet/{itemId}": {
      "schema": "CabinetItem",
      "description": "Items in the user's cabinet."
    },
    "/users/{userId}/scanHistory/{scanId}": {
      "schema": "ScanResult",
      "description": "User's scan history."
    },
    "/users/{userId}/chatMessages/{messageId}": {
      "schema": "ChatMessage",
      "description": "User's chat message history."
    }
  }
}
